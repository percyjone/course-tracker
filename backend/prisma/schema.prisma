generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id          Int      @id @default(autoincrement())
  courseName  String
  instructor  String
  category    String
  duration    String
  status      String   @default("Not Started")
  description String?
  createdAt   DateTime @default(now())
}